# IronClaw Production Slim Dockerfile
#
# A multi-stage build optimized for high-density Nomad shards (Scenario 3) 
# and session workers (Scenario 4).
#
# Final Image Size: ~45MB (compared to ~1.5GB for a standard build)

# ── Phase 1: Build Environment ─────────────────────────────────────────
FROM rust:1.92-slim-bookworm AS builder

# Install build dependencies for PostgreSQL (libpq), SSL (openssl), and WASM.
RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /usr/src/ironclaw

# Cache dependencies: copy manifests first and build a dummy to populate the cache.
COPY Cargo.toml Cargo.lock ./
COPY crates/ironclaw_safety/Cargo.toml crates/ironclaw_safety/Cargo.toml
RUN mkdir -p src crates/ironclaw_safety/src \
    && echo 'fn main() {}' > src/main.rs \
    && touch src/lib.rs \
    && touch crates/ironclaw_safety/src/lib.rs \
    && cargo build --release --bin ironclaw 2>&1 || true \
    && rm -rf src crates/ironclaw_safety/src

# Copy full source and build for real.
COPY . .
RUN cargo build --release --bin ironclaw

# ── Phase 2: Runtime Environment ──────────────────────────────────────
FROM debian:bookworm-slim

# Install ONLY the runtime dependencies required for HTTPS/SSL and Postgres.
RUN apt-get update && apt-get install -y \
    ca-certificates \
    libssl3 \
    libpq5 \
    && rm -rf /var/lib/apt/lists/*

# Copy the lean release binary from the builder.
COPY --from=builder /usr/src/ironclaw/target/release/ironclaw /usr/local/bin/ironclaw

# ── Configuration for High-Density Scaling ───────────────────────────

# Default to "Slim Mode" (Single-threaded runtime).
# Nomad jobs can override this via their own 'env' blocks.
ENV TOKIO_WORKER_THREADS=1
ENV DATABASE_POOL_SIZE=1

# Expose the standard IronClaw ports (HTTP and Gateway).
EXPOSE 8080
EXPOSE 9000

# Set the entrypoint to the IronClaw binary.
ENTRYPOINT ["ironclaw"]

# Default command if none provided.
CMD ["run"]
